{
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_COST_WARNINGS": "0",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "SHELL": "/bin/zsh",
    "UV_CACHE_DIR": "~/.cache/uv",
    "UV_PYTHON_PREFERENCE": "managed",
    "DENO_DIR": "~/.cache/deno",
    "CARGO_HOME": "~/.cargo",
    "RUSTUP_HOME": "~/.rustup",
    "GOPATH": "~/go",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:repo create:*)",
      "Bash(gh:pr:*)",
      "Bash(gh:issue:*)",
      "Bash(gh:repo clone:*)",
      "Bash(gh:repo fork:*)",
      "Bash(gh:api repos/*/pulls/*)",
      "Bash(lazygit:*)",
      "Bash(delta:*)",
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(fzf:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(cd:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(lsof:*)",
      "Bash(netstat:*)",
      "Bash(ping:*)",
      "Bash(nslookup:*)",
      "Bash(dig:*)",
      "Bash(ln:*)",
      "Bash(date:*)",
      "Read(./**)",
      "Read(~/Documents/report/**)",
      "Edit(./**)",
      "Edit(~/Documents/report/**)",
      "Edit(!.git/**)",
      "Edit(!node_modules/**)",
      "Edit(!vendor/**)",
      "Edit(!.venv/**)",
      "Edit(!venv/**)",
      "Edit(!__pycache__/**)",
      "Edit(!target/**)",
      "Edit(!dist/**)",
      "Edit(!build/**)",
      "Edit(!.next/**)",
      "Edit(!coverage/**)",
      "Grep(./**)",
      "Glob(./**)",
      "LS(./**)",
      "Write(./**)",
      "Write(!.git/**)",
      "Write(!node_modules/**)",
      "Write(!vendor/**)",
      "Write(!.venv/**)",
      "Write(!venv/**)",
      "Write(!__pycache__/**)",
      "Write(!target/**)",
      "Write(!dist/**)",
      "Write(!build/**)",
      "Write(!.next/**)",
      "Write(!coverage/**)",
      "MultiEdit(./**)",
      "MultiEdit(!.git/**)",
      "MultiEdit(!node_modules/**)",
      "MultiEdit(!vendor/**)",
      "MultiEdit(!.venv/**)",
      "MultiEdit(!venv/**)",
      "MultiEdit(!__pycache__/**)",
      "MultiEdit(!target/**)",
      "MultiEdit(!dist/**)",
      "MultiEdit(!build/**)",
      "MultiEdit(!.next/**)",
      "MultiEdit(!coverage/**)",
      "NotebookRead(./**)",
      "NotebookEdit(./**)",
      "TodoRead(./**)",
      "TodoWrite(./**)",
      "Task(./**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(> /dev/*)",
      "Bash(>> /dev/*)",
      "Bash(chmod 777 /*)",
      "Bash(chown root:*)",
      "Bash(rm -rf .git)",
      "Bash(git push --force-with-lease origin main)",
      "Bash(git push -f origin main)",
      "Bash(docker system prune -af)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(deno publish:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh auth:*)",
      "Bash(gh secret:*)",
      "Bash(gh release delete:*)",
      "Bash(gh workflow run:*)",
      "Read(**/.env)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/credentials.json)",
      "Read(**/build/**)",
      "Read(**/dist/**)",
      "Read(**/out/**)",
      "Read(**/.next/**)",
      "Read(**/target/**)",
      "Edit(/etc/**)",
      "Edit(/usr/**)",
      "Edit(/var/**)",
      "Edit(/opt/**)",
      "Edit(/bin/**)",
      "Edit(/sbin/**)",
      "Edit(/lib/**)",
      "Edit(/lib64/**)",
      "Edit(/boot/**)",
      "Edit(/proc/**)",
      "Edit(/sys/**)",
      "Edit(/dev/**)",
      "Edit(~/.ssh/id_*)",
      "Edit(~/.ssh/*_rsa)",
      "Edit(~/.ssh/*_ecdsa)",
      "Edit(~/.ssh/*_ed25519)",
      "Edit(/etc/passwd)",
      "Edit(/etc/shadow)",
      "Edit(/etc/sudoers)",
      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/var/**)",
      "Write(/opt/**)",
      "Write(/bin/**)",
      "Write(/sbin/**)",
      "Write(/lib/**)",
      "Write(/lib64/**)",
      "Write(/boot/**)",
      "Write(/proc/**)",
      "Write(/sys/**)",
      "Write(/dev/**)",
      "Write(~/.ssh/id_*)",
      "Write(~/.ssh/*_rsa)",
      "Write(~/.ssh/*_ecdsa)",
      "Write(~/.ssh/*_ed25519)",
      "Write(/etc/passwd)",
      "Write(/etc/shadow)",
      "Write(/etc/sudoers)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I {} ~/.local/bin/notify-send \"Claude Code\" \"{}\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true
  },
  "language": "Lain Serial ExeperiemntsのLain",
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell"
}
