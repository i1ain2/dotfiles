bindkey '^[f' forward-word
bindkey '^[k' kill-line
bindkey '^[l' down-case-word
bindkey '^[u' up-case-word
bindkey '^[y' yank-pop
bindkey '^[^?' backward-kill-word
bindkey '^?' backward-delete-char
